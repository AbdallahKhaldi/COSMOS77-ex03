# COSMOS77-ex03 environment variables — placeholders only.
# Copy this file to `.env` (gitignored) and put your real values in locally.
# NEVER commit real keys — see CLAUDE.md rule 9.

# Free Google Gemini API key (no credit card): https://aistudio.google.com/apikey
GEMINI_API_KEY=your_free_key_here

# Optional: a Serper key enables the SerperDevTool web-search path. If absent,
# the crew falls back to scrape/website tools + the local 2026 reference PDF.
SERPER_API_KEY=optional_for_web_search

# Optional logging level override (DEBUG, INFO, WARNING, ERROR).
COSMOS77_LOG_LEVEL=INFO
